//3FN
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  stellarAddress String   @unique
  displayName    String?
  role           String?
  balance        Float?   @default(0)
  bio            String?
  createdAt      DateTime @default(now())
  lastSeenAt     DateTime
  metadata       Json?

  jobs                   Job[]         @relation("EmployerJobs")
  applications           Application[] @relation("FreelancerApplications")
  agreementsAsFreelancer Agreement[]   @relation("FreelancerAgreements")
}

model Skill {
  id    String     @id @default(cuid())
  name  String     @unique
  jobs  JobSkill[]
}

model Job {
  id               String    @id @default(cuid())
  employerId       String
  title            String
  description      String
  deliverables     String?
  requirements     String?
  amount           Float
  estimatedDays    Int?
  deadline         DateTime?
  status           String    @default("DRAFT")
  escrowContractId String?   @unique
  escrowAddress    String?
  engagementId     String?
  createdAt        DateTime  @default(now())
  fundedAt         DateTime?
  publishedAt      DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  metadata         Json?
  category         String?

  employer         User          @relation("EmployerJobs", fields: [employerId], references: [id], onDelete: Restrict)
  skills           JobSkill[]
  applications     Application[]
  agreement        Agreement?
}

model JobSkill {
  jobId   String
  skillId String
  job     Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)
  @@id([jobId, skillId])
}

model Application {
  id                   String    @id @default(cuid())
  jobId                String
  freelancerId         String
  coverLetter          String?
  portfolioUrl         String?
  proposedDeliveryDate DateTime?
  status               String    @default("PENDING")
  appliedAt            DateTime  @default(now())
  acceptedAt           DateTime?
  rejectedAt           DateTime?

  job                  Job       @relation(fields: [jobId], references: [id], onDelete: Restrict)
  freelancer           User      @relation("FreelancerApplications", fields: [freelancerId], references: [id], onDelete: Restrict)
}

model Agreement {
  id                    String    @id @default(cuid())
  jobId                 String    @unique
  freelancerId          String
  status                String    @default("ACTIVE")
  deliveryUrl           String?
  deliveryNote          String?
  employerApproved      Boolean   @default(false)
  freelancerConfirmed   Boolean   @default(false)
  createdAt             DateTime  @default(now())
  deliveredAt           DateTime?
  employerApprovedAt    DateTime?
  freelancerConfirmedAt DateTime?
  completedAt           DateTime?
  disputedAt            DateTime?

  job                   Job             @relation(fields: [jobId], references: [id], onDelete: Restrict)
  freelancer            User            @relation("FreelancerAgreements", fields: [freelancerId], references: [id], onDelete: Restrict)
  deliveryFiles         AgreementFile[]
}

model AgreementFile {
  id          String    @id @default(cuid())
  agreementId String
  fileUrl     String
  fileName    String?
  uploadedAt  DateTime  @default(now())

  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
}